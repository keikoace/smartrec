# ─── Shopify App Credentials ───────────────────────────────────────────────────
# Get these from your Shopify Partners dashboard → Apps → your app → App setup
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# The public URL where this app is hosted (no trailing slash)
# e.g. https://smartrec.up.railway.app
APP_URL=https://your-app-url.railway.app

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Railway provides this automatically as ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@localhost:5432/smartrec

# ─── App Settings ──────────────────────────────────────────────────────────────
# Random 32+ character string — used to sign session cookies
SESSION_SECRET=change_me_to_a_long_random_string

NODE_ENV=production
PORT=3000

# ─── Optional: Scopes (defaults shown) ─────────────────────────────────────────
# SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_script_tags
